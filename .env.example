# Student Hub 环境变量配置
# 复制此文件为 .env 并填入你的真实值（.env 不会被提交到 git）
#
# ==================== 两种运行方式 ====================
# 本地 venv 直接运行：
#   DB_HOST=localhost
#   DB_PORT=3306
#
# Docker Compose 运行：
#   DB_HOST=db        （容器间通过服务名通信）
#   DB_PORT=3306      （容器内部端口，不是映射端口）
#   docker compose up -d 即可，会自动读取 .env 中的变量

# ==================== MySQL 数据库 ====================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=你的MySQL密码
DB_NAME=student_pro_db
DB_PORT=3306

# ==================== JWT 认证 ====================
# 生产环境请换成随机字符串（例如：openssl rand -hex 32）
JWT_SECRET_KEY=student-hub-secret-key-change-in-production-2026
JWT_EXPIRE_MINUTES=1440

# ==================== 限流 ====================
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_GLOBAL=60/minute
